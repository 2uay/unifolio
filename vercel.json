{
  "buildCommand": "cd unifolio-wealth-core && npm install && npm run build",
  "outputDirectory": "unifolio-wealth-core/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/billing/cron-crypto-renewals",
      "schedule": "0 12 * * *"
    }
  ]
}
