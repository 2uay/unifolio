{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.unifolio.pro" }],
      "destination": "https://unifolio.pro/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.unifolio.ca" }],
      "destination": "https://unifolio.ca/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/billing/cron-crypto-renewals",
      "schedule": "0 12 * * *"
    }
  ]
}
